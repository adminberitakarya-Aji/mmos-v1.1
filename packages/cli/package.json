{
  "name": "@mmos/cli",
  "version": "1.0.0",
  "description": "Official Command Line Interface (CLI) for MMOS.",
  "keywords": [
    "mmos",
    "cli",
    "workflow",
    "orchestration",
    "ai",
    "automation"
  ],
  "homepage": "https://github.com/mmos/mmos",
  "repository": {
    "type": "git",
    "url": "https://github.com/mmos/mmos.git",
    "directory": "packages/cli"
  },
  "license": "Apache-2.0",
  "author": "MMOS Contributors",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mmos": "./dist/bin/mmos.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mmos/sdk": "workspace:*",
    "@mmos/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}