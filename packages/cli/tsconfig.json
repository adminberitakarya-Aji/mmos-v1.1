{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",

    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "noEmitOnError": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },
  "include": [
    "index.ts",
    "bin/**/*.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "examples",
    "test"
  ],
  "references": [
    {
      "path": "../shared"
    },
    {
      "path": "../sdk"
    }
  ]
}