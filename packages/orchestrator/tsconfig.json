{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "noEmitOnError": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "test"
  ],
  "references": [
    { "path": "../core/composition" },
    { "path": "../core/execution" },
    { "path": "../runtime/planner" },
    { "path": "../runtime/scheduler" },
    { "path": "../runtime/queue" },
    { "path": "../runtime/dispatcher" },
    { "path": "../runtime/executor" }
  ]
}
