{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mmos.dev/core/capability.schema.json",
  "title": "MMOS Capability",
  "description": "Capability definition for MMOS AI Orchestration Platform",
  "type": "object",
  "additionalProperties": false,

  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],

  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "mmos/v1"
    },

    "kind": {
      "type": "string",
      "const": "Capability"
    },

    "metadata": {
      "$ref": "#/$defs/Metadata"
    },

    "spec": {
      "$ref": "#/$defs/Spec"
    },

    "status": {
      "$ref": "#/$defs/Status"
    }
  },

  "$defs": {

    "Metadata": {
      "type": "object",
      "additionalProperties": false,

      "required": [
        "name",
        "version"
      ],

      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-zA-Z0-9._-]+$"
        },

        "displayName": {
          "type": "string"
        },

        "description": {
          "type": "string"
        },

        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },

        "author": {
          "type": "string"
        },

        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },

        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },

        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },

        "createdAt": {
          "type": "string",
          "format": "date-time"
        },

        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },

    "Spec": {
      "type": "object",
      "additionalProperties": false,

      "required": [
        "category",
        "inputs",
        "outputs"
      ],

      "properties": {

        "category": {
          "type": "string",
          "enum": [
            "llm",
            "tool",
            "api",
            "database",
            "memory",
            "workflow",
            "event",
            "human",
            "system",
            "plugin"
          ]
        },

        "description": {
          "type": "string"
        },

        "provider": {
          "type": "string"
        },

        "version": {
          "type": "string"
        },

        "inputs": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/Parameter"
          }
        },

        "outputs": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/Parameter"
          }
        },

        "configuration": {
          "type": "object",
          "additionalProperties": true
        },

        "permissions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },

        "timeout": {
          "type": "integer",
          "minimum": 0
        },

        "retryable": {
          "type": "boolean",
          "default": false
        }
      }
    },

    "Parameter": {
      "type": "object",
      "additionalProperties": false,

      "required": [
        "type"
      ],

      "properties": {

        "type": {
          "type": "string",
          "enum": [
            "string",
            "number",
            "integer",
            "boolean",
            "object",
            "array",
            "file",
            "image",
            "audio",
            "video",
            "binary",
            "any"
          ]
        },

        "description": {
          "type": "string"
        },

        "required": {
          "type": "boolean",
          "default": false
        },

        "default": {},

        "enum": {
          "type": "array"
        }
      }
    },

    "Status": {
      "type": "object",
      "additionalProperties": false,

      "required": [
        "state"
      ],

      "properties": {

        "state": {
          "type": "string",
          "enum": [
            "draft",
            "validated",
            "registered",
            "available",
            "deprecated"
          ]
        }
      }
    }
  },

  "examples": [
    {
      "apiVersion": "mmos/v1",
      "kind": "Capability",
      "metadata": {
        "name": "generate-text",
        "version": "1.0.0"
      },
      "spec": {
        "category": "llm",
        "description": "Generate text using an LLM.",
        "provider": "openai",
        "inputs": {
          "prompt": {
            "type": "string",
            "required": true
          },
          "temperature": {
            "type": "number"
          }
        },
        "outputs": {
          "text": {
            "type": "string"
          },
          "usage": {
            "type": "object"
          }
        },
        "timeout": 60000,
        "retryable": true
      },
      "status": {
        "state": "available"
      }
    }
  ]
}