{
  "name": "@mmos/core-composition",
  "version": "1.0.0",
  "description": "Core Composition package for MMOS AI Orchestration Platform",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "schemas",
    "README.md"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --watch --format esm --dts",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write .",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mmos",
    "composition",
    "workflow",
    "orchestration",
    "ai",
    "agent",
    "runtime",
    "typescript"
  ],
  "author": "MMOS Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/mmos/mmos.git",
    "directory": "packages/core/composition"
  },
  "homepage": "https://github.com/mmos/mmos",
  "bugs": {
    "url": "https://github.com/mmos/mmos/issues"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.30.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}