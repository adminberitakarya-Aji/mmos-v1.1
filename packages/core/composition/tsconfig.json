{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "./dist",

    "composite": true,
    "declaration": true,
    "declarationMap": true,

    "sourceMap": true,

    "noEmit": false,

    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@mmos/shared": ["../../../packages/shared"],
      "@mmos/shared/*": ["../../../packages/shared/*"]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "test"
  ],
  "references": [
    { "path": "../../../packages/shared" }
  ]
}
