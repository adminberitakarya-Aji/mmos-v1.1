{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mmos.dev/schemas/runtime/execution-plan.schema.json",
  "title": "Execution Plan",
  "description": "Execution plan generated by the Runtime Planner.",
  "type": "object",
  "additionalProperties": false,

  "required": [
    "id",
    "compositionId",
    "workflowId",
    "version",
    "status",
    "nodes",
    "edges",
    "parallelGroups",
    "metadata"
  ],

  "properties": {
    "id": {
      "type": "string",
      "description": "Unique execution plan identifier."
    },

    "compositionId": {
      "type": "string"
    },

    "workflowId": {
      "type": "string"
    },

    "version": {
      "type": "string"
    },

    "status": {
      "type": "string",
      "enum": [
        "draft",
        "planned",
        "optimized",
        "failed"
      ]
    },

    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },

    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },

    "parallelGroups": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/parallelGroup"
      }
    },

    "metadata": {
      "$ref": "#/$defs/metadata"
    }
  },

  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,

      "required": [
        "id",
        "taskId",
        "name",
        "agentId",
        "capabilityId",
        "dependencies"
      ],

      "properties": {
        "id": {
          "type": "string"
        },

        "taskId": {
          "type": "string"
        },

        "name": {
          "type": "string"
        },

        "agentId": {
          "type": "string"
        },

        "capabilityId": {
          "type": "string"
        },

        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },

        "memory": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },

        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },

        "condition": {
          "type": [
            "string",
            "null"
          ]
        },

        "parallelizable": {
          "type": "boolean",
          "default": false
        }
      }
    },

    "edge": {
      "type": "object",
      "additionalProperties": false,

      "required": [
        "from",
        "to"
      ],

      "properties": {
        "from": {
          "type": "string"
        },

        "to": {
          "type": "string"
        }
      }
    },

    "parallelGroup": {
      "type": "object",
      "additionalProperties": false,

      "required": [
        "id",
        "nodes"
      ],

      "properties": {
        "id": {
          "type": "string"
        },

        "nodes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },

    "metadata": {
      "type": "object",
      "additionalProperties": false,

      "required": [
        "createdAt",
        "plannerVersion"
      ],

      "properties": {
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },

        "plannerVersion": {
          "type": "string"
        },

        "optimizationLevel": {
          "type": "string",
          "enum": [
            "none",
            "basic",
            "standard",
            "aggressive"
          ]
        },

        "estimatedDuration": {
          "type": "integer",
          "minimum": 0
        },

        "estimatedCost": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  }
}