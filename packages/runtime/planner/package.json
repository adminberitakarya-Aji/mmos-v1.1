{
  "name": "@mmos/runtime-planner",
  "version": "1.0.0",
  "description": "MMOS Runtime Planner - Builds optimized execution plans from workflow compositions.",
  "keywords": [
    "mmos",
    "runtime",
    "planner",
    "workflow",
    "execution-plan",
    "dag",
    "orchestration"
  ],
  "homepage": "https://github.com/mmos/mmos",
  "repository": {
    "type": "git",
    "url": "https://github.com/mmos/mmos.git",
    "directory": "packages/runtime/planner"
  },
  "license": "Apache-2.0",
  "author": "MMOS Contributors",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "schemas"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mmos/core-agent": "workspace:*",
    "@mmos/core-artifact": "workspace:*",
    "@mmos/core-capability": "workspace:*",
    "@mmos/core-composition": "workspace:*",
    "@mmos/core-execution": "workspace:*",
    "@mmos/core-memory": "workspace:*",
    "@mmos/core-task": "workspace:*",
    "@mmos/core-workflow": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}