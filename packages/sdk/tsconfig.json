{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "noEmitOnError": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "examples",
    "test"
  ],
  "references": [
    {
      "path": "../shared"
    },
    {
      "path": "../core/composition"
    },
    {
      "path": "../core/workflow"
    },
    {
      "path": "../core/task"
    },
    {
      "path": "../core/agent"
    },
    {
      "path": "../core/capability"
    },
    {
      "path": "../core/artifact"
    },
    {
      "path": "../core/memory"
    },
    {
      "path": "../core/event"
    },
    {
      "path": "../core/execution"
    },
    {
      "path": "../orchestrator"
    }
  ]
}
