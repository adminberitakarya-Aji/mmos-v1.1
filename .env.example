# ------------------------------------------------------------------------------
# MMOS — environment variables template
# Copy to `.env` and fill in real values. Never commit `.env`.
# ------------------------------------------------------------------------------

# Node
NODE_ENV=development
LOG_LEVEL=info

# HTTP
HTTP_PORT=8080
HTTP_HOST=0.0.0.0

# AI providers (use one or more)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
QWEN_API_KEY=
DEEPSEEK_API_KEY=

# Default provider used when composition does not specify one
MMOS_DEFAULT_PROVIDER=openai
MMOS_DEFAULT_MODEL=gpt-4o-mini

# Storage (artifacts)
MMOS_ARTIFACT_STORAGE=local
MMOS_ARTIFACT_PATH=./.artifacts

# Event bus
MMOS_EVENT_BUS=memory
