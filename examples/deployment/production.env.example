# examples/deployment/production.env.example
#
# Reference environment configuration for MMOS production deployments,
# per docs/deployment/docker.md ("Environment Variables" / "Secrets") and
# docs/deployment/production.md.
#
# THIS FILE CONTAINS NO REAL SECRETS. Copy it to `.env`, replace every
# placeholder value, and NEVER commit the resulting `.env` file to source
# control (docs/deployment/docker.md: "Secrets should never be committed
# to source control.").
#
# In Kubernetes, the equivalent sensitive values belong in a Secret, not a
# ConfigMap — see examples/deployment/kubernetes.yaml and
# docs/deployment/kubernetes.md ("Secrets should never be stored in
# ConfigMaps.").

# -----------------------------------------------------------------------
# General
# -----------------------------------------------------------------------
MMOS_ENV=production
MMOS_VERSION=1.0.0
MMOS_IMAGE_REGISTRY=your-registry.example.com/mmos
LOG_LEVEL=info
LOG_FORMAT=json

# -----------------------------------------------------------------------
# Database Connection (PostgreSQL)
# -----------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mmos
POSTGRES_USER=mmos
POSTGRES_PASSWORD=CHANGE_ME_use_a_generated_secret
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# -----------------------------------------------------------------------
# Redis Connection
# -----------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_use_a_generated_secret
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# -----------------------------------------------------------------------
# NATS Connection (platform event bus — docs/deployment/docker.md "NATS")
# -----------------------------------------------------------------------
NATS_HOST=nats
NATS_PORT=4222
NATS_URL=nats://${NATS_HOST}:${NATS_PORT}

# -----------------------------------------------------------------------
# Object Storage (images, videos, audio, documents, artifacts)
# -----------------------------------------------------------------------
OBJECT_STORAGE_ENDPOINT=https://object-storage.example.com
OBJECT_STORAGE_ACCESS_KEY=CHANGE_ME
OBJECT_STORAGE_SECRET_KEY=CHANGE_ME_use_a_generated_secret
OBJECT_STORAGE_BUCKET=mmos-artifacts
OBJECT_STORAGE_REGION=us-east-1

# -----------------------------------------------------------------------
# Gateway
# -----------------------------------------------------------------------
GATEWAY_PORT=8080
GATEWAY_PUBLIC_URL=https://api.mmos.example.com

# -----------------------------------------------------------------------
# Dashboard API
# -----------------------------------------------------------------------
DASHBOARD_API_PORT=8081

# -----------------------------------------------------------------------
# Authentication (docs/deployment/docker.md "Authentication Keys")
# -----------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_use_a_long_random_secret
JWT_EXPIRES_IN=3600
AUTH_ISSUER=mmos-platform

# -----------------------------------------------------------------------
# Scheduler / Worker
# -----------------------------------------------------------------------
WORKER_REPLICAS=4
SCHEDULER_MAX_CONCURRENCY=8
EXECUTION_DEFAULT_TIMEOUT_MS=300000

# -----------------------------------------------------------------------
# Provider Credentials (docs/providers/*) — never bake into images
# -----------------------------------------------------------------------
OPENAI_API_KEY=CHANGE_ME
ANTHROPIC_API_KEY=CHANGE_ME
GEMINI_API_KEY=CHANGE_ME
QWEN_API_KEY=CHANGE_ME
DEEPSEEK_API_KEY=CHANGE_ME

# -----------------------------------------------------------------------
# Monitoring (docs/deployment/monitoring.md)
# -----------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9090
