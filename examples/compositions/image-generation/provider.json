{
  "$schema": "../../../schemas/provider.schema.json",

  "id": "provider.openai",

  "name": "openai",

  "displayName": "OpenAI",

  "description": "Default AI provider configuration for the Image Generation composition.",

  "type": "openai",

  "version": "1.0.0",

  "status": "active",

  "metadata": {
    "name": "OpenAI Provider",
    "description": "Reference provider configuration for AI image generation.",
    "version": "1.0.0",
    "tags": [
      "provider",
      "openai",
      "image-generation",
      "creative",
      "example"
    ]
  },

  "configuration": {
    "endpoint": "https://api.openai.com/v1",

    "authentication": {
      "method": "api-key",
      "credentialRef": {
        "id": "secret.openai-api-key",
        "type": "custom",
        "name": "OPENAI_API_KEY"
      }
    },

    "defaultModel": "gpt-image-1",

    "timeout": 60000,

    "maxRetries": 3,

    "retryBackoff": "exponential",

    "rateLimit": {
      "requestsPerMinute": 300,
      "imagesPerMinute": 100
    },

    "streaming": false,

    "healthCheck": {
      "enabled": true,
      "interval": 60
    }
  },

  "models": [
    {
      "id": "model.gpt-image-1",
      "name": "gpt-image-1",
      "provider": "openai",
      "type": "image-generation"
    },
    {
      "id": "model.gpt-5",
      "name": "gpt-5",
      "provider": "openai",
      "type": "reasoning"
    }
  ],

  "capabilities": [
    {
      "id": "capability.reasoning"
    },
    {
      "id": "capability.image-generation"
    },
    {
      "id": "capability.image-analysis"
    },
    {
      "id": "capability.artifact"
    }
  ],

  "authentication": {
    "method": "api-key",
    "credentialRef": {
      "id": "secret.openai-api-key",
      "type": "custom"
    }
  },

  "limits": {
    "maxRequestsPerMinute": 300,
    "maxImagesPerRequest": 10,
    "maxResolution": "2048x2048",
    "supportsStreaming": false,
    "supportsBatch": true
  },

  "health": {
    "enabled": true,
    "checkInterval": 60,
    "timeout": 5000
  },

  "pricing": {
    "currency": "USD",
    "billingModel": "payg"
  },

  "tags": [
    "provider",
    "openai",
    "image-generation",
    "creative"
  ],

  "labels": {
    "environment": "development",
    "domain": "image-generation",
    "default": "true"
  }
}