{
  "$schema": "../../../schemas/runtime.schema.json",

  "engine": "mmos-runtime",

  "scheduler": {
    "strategy": "fifo",
    "maxConcurrency": 8
  },

  "dispatcher": {
    "strategy": "least-load",
    "workerSelection": "automatic"
  },

  "executor": {
    "maxWorkers": 8,
    "timeout": 300000,
    "retryPolicy": {
      "maxAttempts": 3,
      "backoff": "exponential"
    }
  },

  "eventBus": {
    "enabled": true,
    "provider": "internal"
  },

  "memory": {
    "id": "memory.image-generation",
    "type": "working",
    "scope": "workflow"
  },

  "providers": [
    {
      "id": "provider.openai",
      "name": "OpenAI",
      "type": "openai"
    }
  ],

  "logging": {
    "level": "info",
    "structured": true
  },

  "monitoring": {
    "enabled": true,
    "metrics": true,
    "tracing": true
  },

  "security": {
    "authentication": true,
    "authorization": true,
    "encryption": true
  },

  "metadata": {
    "name": "Image Generation Runtime",
    "description": "Reference runtime configuration for the Image Generation composition.",
    "version": "1.0.0",
    "tags": [
      "runtime",
      "image-generation",
      "creative",
      "multimodal",
      "example"
    ],
    "labels": {
      "environment": "development",
      "deployment": "single-node",
      "domain": "image-generation"
    }
  }
}