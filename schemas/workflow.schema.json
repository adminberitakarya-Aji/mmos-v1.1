{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mmos.dev/v1/workflow.schema.json",
  "title": "MMOS Workflow",
  "description": "Canonical schema for an MMOS Workflow.",
  "type": "object",

  "required": [
    "id",
    "name",
    "version",
    "tasks"
  ],

  "properties": {
    "id": {
      "$ref": "./common/identifier.schema.json"
    },

    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },

    "displayName": {
      "type": "string"
    },

    "description": {
      "type": "string"
    },

    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },

    "status": {
      "$ref": "./common/status.schema.json"
    },

    "metadata": {
      "$ref": "./common/metadata.schema.json"
    },

    "inputs": {
      "type": "object",
      "additionalProperties": true
    },

    "outputs": {
      "type": "object",
      "additionalProperties": true
    },

    "variables": {
      "type": "object",
      "additionalProperties": true
    },

    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./task.schema.json"
      }
    },

    "memory": {
      "$ref": "./memory.schema.json"
    },

    "capabilities": {
      "type": "array",
      "items": {
        "$ref": "./capability.schema.json"
      }
    },

    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "./artifact.schema.json"
      }
    },

    "timeout": {
      "type": "integer",
      "minimum": 0
    },

    "retryPolicy": {
      "type": "object",
      "properties": {
        "maxAttempts": {
          "type": "integer",
          "minimum": 1
        },
        "backoff": {
          "type": "string",
          "enum": [
            "fixed",
            "linear",
            "exponential"
          ]
        }
      },
      "additionalProperties": false
    },

    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },

    "labels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },

  "additionalProperties": false
}