{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mmos.dev/v1/common/error.schema.json",
  "title": "MMOS Error",
  "description": "Reusable error schema for MMOS APIs, Runtime, Providers, and platform components.",
  "type": "object",

  "required": [
    "code",
    "message"
  ],

  "properties": {
    "code": {
      "type": "string",
      "description": "Machine-readable error code.",
      "examples": [
        "INVALID_REQUEST",
        "UNAUTHORIZED",
        "NOT_FOUND",
        "PROVIDER_TIMEOUT",
        "EXECUTION_FAILED"
      ]
    },

    "message": {
      "type": "string",
      "description": "Human-readable error message."
    },

    "details": {
      "type": "object",
      "description": "Additional structured information about the error.",
      "additionalProperties": true
    },

    "field": {
      "type": "string",
      "description": "The field associated with the error, if applicable."
    },

    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warning",
        "error",
        "critical"
      ],
      "default": "error"
    },

    "retryable": {
      "type": "boolean",
      "description": "Indicates whether retrying the operation may succeed.",
      "default": false
    },

    "correlationId": {
      "$ref": "./identifier.schema.json"
    },

    "timestamp": {
      "$ref": "./timestamp.schema.json"
    }
  },

  "additionalProperties": false
}