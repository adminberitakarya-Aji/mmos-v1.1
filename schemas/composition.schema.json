{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mmos.dev/v1/composition.schema.json",
  "title": "MMOS Composition",
  "description": "Canonical schema for an MMOS Composition.",
  "type": "object",

  "required": [
    "id",
    "name",
    "version",
    "workflows"
  ],

  "properties": {
    "id": {
      "$ref": "./common/identifier.schema.json"
    },

    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },

    "displayName": {
      "type": "string"
    },

    "description": {
      "type": "string"
    },

    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },

    "status": {
      "$ref": "./common/status.schema.json"
    },

    "metadata": {
      "$ref": "./common/metadata.schema.json"
    },

    "runtime": {
      "$ref": "./runtime.schema.json"
    },

    "workflows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./workflow.schema.json"
      }
    },

    "capabilities": {
      "type": "array",
      "items": {
        "$ref": "./capability.schema.json"
      }
    },

    "providers": {
      "type": "array",
      "items": {
        "$ref": "./provider.schema.json"
      }
    },

    "memory": {
      "$ref": "./memory.schema.json"
    },

    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "./artifact.schema.json"
      }
    },

    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },

    "labels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },

  "additionalProperties": false
}